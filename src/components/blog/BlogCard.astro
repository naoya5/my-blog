---
import type { CollectionEntry } from 'astro:content';
import Tag from '@components/ui/Tag.astro';
import { formatDate } from '@utils/formatDate';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---

<article class="list-divider first:border-t-0">
  <a href={`/blog/${post.slug}/`} class="group block py-4 sm:py-5">
    <div class="grid gap-2.5 sm:grid-cols-[148px_minmax(0,1fr)] sm:gap-5">
      <div class="space-y-2 sm:pt-1">
        <div class="text-[11px] font-semibold uppercase tracking-[0.24em]" style="color: rgb(var(--text-muted));">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
        </div>
        <div class="inline-flex items-center rounded-full border px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.18em]" style="border-color: rgb(var(--line)); color: rgb(var(--text-muted));">
          {post.data.category === 'daily' ? 'Daily Signal' : 'Deep Dive'}
        </div>
      </div>

      <div class="min-w-0">
        <div class="flex items-start justify-between gap-4">
          <h3 class="max-w-3xl text-[1.55rem] leading-[1.38] tracking-tight transition-colors sm:text-[1.85rem] group-hover:text-[rgb(var(--accent))]" style="font-family: var(--font-display);">
            {post.data.title}
          </h3>
          <span class="hidden pt-1 text-base transition-transform duration-200 group-hover:translate-x-1 sm:inline-block" style="color: rgb(var(--text-muted));" aria-hidden="true">
            →
          </span>
        </div>

        <p class="mt-2 max-w-3xl text-sm leading-7 sm:text-base" style="color: rgb(var(--text-muted));">
          {post.data.description}
        </p>

        <div class="mt-1 flex flex-wrap gap-x-2 gap-y-1">
          {post.data.tags.slice(0, 3).map((tag) => <Tag name={tag} />)}
        </div>
      </div>
    </div>
  </a>
</article>
