---
import BlogCard from '@components/blog/BlogCard.astro';
import Search from '@components/blog/Search.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getSortedPosts } from '@utils/getSortedPosts';

const posts = await getSortedPosts();
---

<BaseLayout 
  title="Archive | Agentic Signal" 
  description="AIエージェント開発、AI駆動ワークフロー構築に関する記事一覧です。"
>
  <section class="mx-auto max-w-4xl">
    <header class="border-b pb-8" style="border-color: rgb(var(--line));">
      <p class="section-kicker">Archive</p>
      <h1 class="page-title">AI Agents & Workflow</h1>
      <p class="page-copy">
        AIエージェント開発、RAG、LLM制御、そしてAIを組み込んだ開発ワークフローについての記録を、公開順に一覧できます。
      </p>
      <div class="mt-7 flex flex-wrap gap-x-6 gap-y-3">
        <a href="/rss.xml" class="inline-link">
          RSS Feed
          <span aria-hidden="true">→</span>
        </a>
        <a href="/blog/page/1/" class="inline-link">
          ページ単位で見る
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </header>

    <div class="mt-8">
      <Search />
    </div>

    <div class="mt-10">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
  </section>
</BaseLayout>
