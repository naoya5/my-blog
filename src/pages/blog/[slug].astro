---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import ReadingTime from '@components/blog/ReadingTime.astro';
import TableOfContents from '@components/blog/TableOfContents.astro';
import Tag from '@components/ui/Tag.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { formatDate } from '@utils/formatDate';
import { getRelatedPosts } from '@utils/getRelatedPosts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true));

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props as Props;
const { Content, headings } = await post.render();
const posts = await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true));
const relatedPosts = getRelatedPosts(post, posts);
const heroImage = post.data.heroImage;

const heroForSchema = heroImage
  ? typeof heroImage === 'string'
    ? heroImage
    : new URL(heroImage.src, Astro.site).toString()
  : new URL('/images/default-og.svg', Astro.site).toString();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: [heroForSchema],
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: [
    {
      '@type': 'Person',
      name: 'Agentic Signal',
    },
  ],
};

// Prevent closing the script tag when serializing untrusted text fields.
const schemaJson = JSON.stringify(schema).replace(/</g, '\\u003c');
---

<BaseLayout
  title={`${post.data.title} | Agentic Signal`}
  description={post.data.description}
  image={heroImage}
  type="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
  tags={post.data.tags}
>
  <script type="application/ld+json" is:inline set:html={schemaJson} />

  <article data-pagefind-body class="mx-auto max-w-3xl">
    <header class="border-b pb-10" style="border-color: rgb(var(--line));">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-semibold uppercase tracking-[0.24em]" style="color: rgb(var(--text-muted));">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        {post.data.updatedDate && <span>Updated {formatDate(post.data.updatedDate)}</span>}
        <ReadingTime content={post.body} />
      </div>

      <h1 class="mt-5 text-balance text-4xl leading-tight sm:text-5xl" style="font-family: var(--font-display);" data-pagefind-meta="title">
        {post.data.title}
      </h1>

      <p class="mt-5 text-base leading-8 sm:text-lg" style="color: rgb(var(--text-muted));">
        {post.data.description}
      </p>

      <div class="mt-6 flex flex-wrap gap-2">
        {post.data.tags.map((tag) => <Tag name={tag} />)}
      </div>

      {heroImage && (
        <div class="mt-10 overflow-hidden rounded-2xl border" style="border-color: rgb(var(--line));">
          {typeof heroImage === 'string' ? (
            <img
              src={heroImage}
              alt={post.data.title}
              width="1200"
              height="630"
              class="aspect-[21/9] w-full object-cover"
              loading="eager"
              decoding="async"
            />
          ) : (
            <Image
              src={heroImage}
              alt={post.data.title}
              width={1200}
              height={630}
              class="aspect-[21/9] w-full object-cover"
              loading="eager"
            />
          )}
        </div>
      )}
    </header>

    {headings.length > 0 && (
      <div class="mt-8">
        <TableOfContents headings={headings} />
      </div>
    )}

    <div class="prose prose-slate mt-10 dark:prose-invert">
      <Content />
    </div>
  </article>

  {relatedPosts.length > 0 && (
    <section class="mx-auto mt-16 max-w-3xl border-t pt-8" style="border-color: rgb(var(--line));">
      <p class="section-kicker">Related Posts</p>
      <h2 class="mt-2 text-2xl">関連記事</h2>
      <div class="mt-4">
        {relatedPosts.slice(0, 2).map((relatedPost) => (
          <article class="list-divider first:border-t-0">
            <a href={`/blog/${relatedPost.slug}/`} class="group block py-5">
              <div class="text-[11px] font-semibold uppercase tracking-[0.24em]" style="color: rgb(var(--text-muted));">
                {formatDate(relatedPost.data.pubDate)}
              </div>
              <h3 class="mt-2 text-xl transition-colors group-hover:text-[rgb(var(--accent))]" style="font-family: var(--font-display);">
                {relatedPost.data.title}
              </h3>
              <p class="mt-2 text-sm leading-7" style="color: rgb(var(--text-muted));">
                {relatedPost.data.description}
              </p>
            </a>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
