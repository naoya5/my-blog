---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getSortedPosts } from '@utils/getSortedPosts';

const posts = await getSortedPosts();
const latestPosts = posts.slice(0, 5);
---

<BaseLayout
  title="Agentic Signal | AIエージェント開発の実践知"
  description="AIエージェント開発とAI駆動のワークフロー構築を中心に、現場で使えるシグナルを発信します。"
  hideFooter={true}
>
  <section class="home-hero mx-auto max-w-4xl border-b pb-12 pt-6 text-center sm:pb-14" style="border-color: rgb(var(--line));">
    <div class="home-avatar" aria-hidden="true">
      <div class="home-avatar-inner">
        <span>AS</span>
      </div>
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="/blog/" class="home-icon-link" aria-label="Blog">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 5.75h12M6 12h12M6 18.25h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <span>Blog</span>
      </a>
      <a href="/blog/page/1/" class="home-icon-link" aria-label="Archive">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 7.5h14M7 5h10a1 1 0 011 1v12a1 1 0 01-1 1H7a1 1 0 01-1-1V6a1 1 0 011-1z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Archive</span>
      </a>
      <a href="/rss.xml" class="home-icon-link" aria-label="RSS Feed">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 17a2 2 0 100 4 2 2 0 000-4zM4 11a9 9 0 019 9M4 5a15 15 0 0115 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <span>RSS</span>
      </a>
      <button type="button" class="home-icon-link" data-search-trigger="site-search-open" aria-label="検索を開く">
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M13.5 13.5L18 18M15.5 8.5a7 7 0 11-14 0 7 7 0 0114 0z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <span>Search</span>
      </button>
    </div>

    <div class="mt-7 flex flex-wrap justify-center gap-x-6 gap-y-3">
      <a href="/blog/" class="inline-link">
        すべての記事を見る
        <span aria-hidden="true">→</span>
      </a>
      <a href="/rss.xml" class="inline-link">
        更新をRSSで受け取る
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <section class="mx-auto mt-10 max-w-4xl">
    <h2 class="text-2xl font-extrabold tracking-tight sm:text-3xl" style="font-family: var(--font-body);">
      Latest Posts
    </h2>

    <div class="mt-8 border-t" style="border-color: rgba(var(--line), 0.9);">
      {latestPosts.map((post) => (
        <article class="border-b py-5 sm:py-6" style="border-color: rgba(var(--line), 0.9);">
          <a
            href={`/blog/${post.slug}/`}
            class="grid gap-2 text-[rgb(var(--text-main))] transition-colors hover:text-[rgb(var(--accent))] sm:grid-cols-[minmax(0,1fr)_140px] sm:items-start sm:gap-6"
          >
            <h3 class="text-base font-extrabold leading-7 sm:text-[1.45rem] sm:leading-[1.5]" style="font-family: var(--font-body);">
              {post.data.title}
            </h3>
            <time
              datetime={post.data.pubDate.toISOString()}
              class="text-xs font-medium tracking-[0.04em] sm:pt-1 sm:text-right sm:text-sm"
              style="color: rgb(var(--text-muted));"
            >
              {post.data.pubDate.toISOString().slice(0, 10)}
            </time>
          </a>
        </article>
      ))}
    </div>

    <div class="mt-6">
      <a href="/blog/" class="inline-link text-sm sm:text-base">
        すべての記事を見る
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
